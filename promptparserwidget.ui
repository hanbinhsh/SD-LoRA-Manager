    border-radius: 4px;
}
QTabBar { background-color: #1a1f29; }
QTabBar::tab {
    background: #1a1f29;
    color: #ccc;
    padding: 10px;
}
QTabBar::tab:selected {
    background: #3d4450;
    color: #fff;
    font-weight: bold;
}
QLabel {
    color: #8c96a0;
    font-weight: bold;
    font-size: 12px;
}
QLineEdit, QTextBrowser, QScrollArea {
    background-color: #16191e;
    border: 1px solid #31363d;
    border-radius: 3px;
    color: #acb2b8;
    padding: 2px;
}
QScrollArea::viewport, QTextBrowser::viewport {
    background-color: transparent;
    border: none;
}
QWidget#scrollAreaWidgetContentsPos, QWidget#scrollAreaWidgetContentsNeg, QWidget#scrollAreaWidgetContentsWd14 {
    background-color: transparent;
}
QLabel#lblImage, QLabel#lblWd14Image {
    background-color: #16191e;
    border: 2px dashed #363c46;
    border-radius: 8px;
    color: #5a6f8a;
    font-size: 16px;
}
QLabel#lblImage:hover, QLabel#lblWd14Image:hover {
    border: 2px dashed #66c0f4;
    background-color: #1e252f;
    color: #66c0f4;
}
QPushButton {
    background-color: #2a3f5a;
    border-radius: 2px;
    color: #66c0f4;
    border: none;
    padding: 6px 12px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #3d5677;
    color: #ffffff;
}
QPushButton:disabled {
    background-color: #2a3038;
    color: #7f8791;
}
QPushButton#btnTranslate:checked {
    background-color: #66c0f4;
    color: #000000;
}
QLabel#lblWd14Status {
    color: #8c96a0;
}</string>
