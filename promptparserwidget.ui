  <property name="styleSheet">
   <string notr="true">/* === 全局背景 (匹配 Mainwindow) === */
QWidget#PromptParserWidget { 
    background-color: #1b2838; 
    color: #dcdedf; 
}

/* === 标题样式 === */
QLabel { 
    color: #8c96a0; 
    font-weight: bold; 
    font-size: 12px; 
}

/* === 核心：统一文本框与滚动区域样式 (复用 Mainwindow QTextBrowser 样式) === */
QTextBrowser, QScrollArea { 
    background-color: #16191e; 
    border: 1px solid #31363d; 
    border-radius: 3px; 
    color: #acb2b8; 
    padding: 2px; /* 给内容留一点呼吸空间，避免滚动条压文字 */
}

/* === 修复圆角白线问题 === */
/* 将 ScrollArea 和 TextBrowser 的视口背景设为透明，
   这样只会显示外层带有圆角的背景颜色，消除直角瑕疵 */
QScrollArea::viewport, QTextBrowser::viewport {
    background-color: transparent;
    border: none;
}

/* Tag 容器内部背景也设为透明 */
QWidget#scrollAreaWidgetContentsPos, QWidget#scrollAreaWidgetContentsNeg {
    background-color: transparent;
}

/* === 图片上传框 === */
QLabel#lblImage {
    background-color: #16191e;
    border: 2px dashed #363c46; /* 边框颜色加深一点 */
    border-radius: 8px;
    color: #5a6f8a;
    font-size: 16px;
}
QLabel#lblImage:hover {
    border: 2px dashed #66c0f4;
    background-color: #1e252f;
    color: #66c0f4;
}

/* === 翻译按钮 (复用 Mainwindow 功能按钮样式) === */
QPushButton#btnTranslate {
    background-color: #2a3f5a; 
    border-radius: 2px; 
    color: #66c0f4; 
    border: none; 
    font-weight: bold;
}
QPushButton#btnTranslate:hover { 
    background-color: #3d5677; 
    color: #ffffff; 
}
QPushButton#btnTranslate:checked { 
    background-color: #66c0f4; 
    color: #000000; 
}
</string>
