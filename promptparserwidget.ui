  <property name="styleSheet">
   <string notr="true">QWidget#PromptParserWidget { background-color: #1b2838; color: #dcdedf; }
QTabWidget::pane {
    border: 1px solid #3d4d5d;
    background-color: #1e252f;
    border-radius: 4px;
}
QLabel {
    color: #8c96a0;
    font-size: 12px;
}
QLineEdit, QTextBrowser, QScrollArea, QComboBox, QDoubleSpinBox, QTreeWidget {
    background-color: #16191e;
    border: 1px solid #31363d;
    border-radius: 3px;
    color: #dcdedf;
    padding: 4px;
}
QCheckBox {
    color: #dcdedf;
    spacing: 6px;
}
QTabBar { background-color: #1a1f29; }
QTabBar::tab {
    background: #1a1f29;
    color: #ccc;
    padding: 10px;
}
QTabBar::tab:selected {
    background: #3d4450;
    color: #fff;
    font-weight: bold;
}
QSlider::groove:horizontal {
    height: 6px;
    background: #27313d;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    width: 14px;
    margin: -4px 0;
    border-radius: 7px;
    background: #66c0f4;
}
QTreeWidget::item {
    min-height: 24px;
}
QHeaderView::section {
    background-color: #212831;
    color: #dcdedf;
    padding: 6px;
    border: none;
    border-right: 1px solid #31363d;
}
QTreeWidget {
    gridline-color: #2b3440;
    selection-background-color: #3d5677;
}
QScrollArea::viewport, QTextBrowser::viewport {
    background-color: transparent;
    border: none;
}
QWidget#scrollAreaWidgetContentsPos, QWidget#scrollAreaWidgetContentsNeg {
    background-color: transparent;
}
QLabel#lblImage, QLabel#lblWd14Image {
    background-color: #16191e;
    border: 2px dashed #363c46;
    border-radius: 8px;
    color: #5a6f8a;
    font-size: 16px;
}
QLabel#lblImage:hover, QLabel#lblWd14Image:hover {
    border: 2px dashed #66c0f4;
    background-color: #1e252f;
    color: #66c0f4;
}
QPushButton {
    background-color: #2a3f5a;
    border-radius: 2px;
    color: #66c0f4;
    border: none;
    padding: 6px 12px;
}
QPushButton:hover { background-color: #3d5677; color: #ffffff; }
QPushButton:disabled {
    background-color: #2a3038;
    color: #7f8791;
}
QPushButton#btnTranslate:checked {
    background-color: #66c0f4;
    color: #000000;
}
QLabel#lblWd14Status, QLabel#lblWd14Elapsed, QLabel#lblWd14Memory {
    color: #8c96a0;
}</string>
