  <property name="styleSheet">
   <string notr="true">QWidget#TagBrowserWidget { background-color: #1b2838; color: #dcdedf; }
QTabWidget::pane {
    border: 1px solid #3d4d5d;
    background-color: #1e252f;
    border-radius: 4px;
}
QLineEdit, QComboBox, QTableView {
    background-color: #16191e;
    border: 1px solid #31363d;
    color: #dcdedf;
    border-radius: 3px;
    padding: 4px;
}
QTabBar { background-color: #1a1f29; }
QTabBar::tab {
    background: #1a1f29;
    color: #ccc;
    padding: 10px;
}
QTabBar::tab:selected {
    background: #3d4450;
    color: #fff;
    font-weight: bold;
}
QPushButton {
    background-color: #2a3f5a;
    border-radius: 2px;
    color: #66c0f4;
    border: none;
    padding: 6px 12px;
}
QPushButton:hover { background-color: #3d5677; color: #ffffff; }
QPushButton:disabled { background-color: #2a3038; color: #7f8791; }
QHeaderView::section {
    background-color: #212831;
    color: #dcdedf;
    padding: 6px;
    border: none;
    border-right: 1px solid #31363d;
}
QTableView {
    gridline-color: #2b3440;
    selection-background-color: #3d5677;
}
QLabel#lblStatus, QLabel#lblUserTagStatus {
    color: #8c96a0;
}</string>
