               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>40</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="groupScan">
            <property name="title">
             <string>扫描选项 / Scanning Options</string>
            </property>
            <layout class="QVBoxLayout" name="verticalLayout_ScanOpts">
             <item>
              <widget class="QCheckBox" name="chkRecursiveLora">
               <property name="toolTip">
