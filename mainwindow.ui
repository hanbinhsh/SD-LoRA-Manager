               </property>
               <property name="text">
                <string>显示空的收藏夹 / Show Empty Collections</string>
               </property>
               <property name="checked">
                <bool>false</bool>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSlider" name="sliderBlur">
