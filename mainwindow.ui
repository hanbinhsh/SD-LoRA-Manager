               </property>
               <property name="maximum">
                <number>32</number>
               </property>
               <property name="value">
                <number>4</number>
               </property>
              </widget>
             </item>
             <item row="0" column="2">
              <spacer name="horizontalSpacer_Perf">
               <property name="orientation">
